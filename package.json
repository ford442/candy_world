{
  "name": "candy_world",
  "version": "1.0.0",
  "description": "A 3D world of rudimentary, but sharp graphically nature - featuring smooth, glossy shapes in a pastel candy-colored landscape.",
  "type": "module",
  "scripts": {
    "dev": "bash dev.sh",
    "preview": "vite preview",
    "build:wasm": "asc assembly/index.ts --outFile src/wasm/candy_physics.wasm --textFile src/wasm/candy_physics.wat --sourceMap --shrinkLevel 0 --optimize --converge --optimizeLevel 3 --enable simd --enable bulk-memory --initialMemory 5 --maximumMemory 256 --target wasm-gc --enable reference-types --enable gc --exportRuntime --bindings esm",
    "build:emcc": "bash emscripten/build.sh",
    "build:ci": "npm run build:wasm && vite build",
    "optimize": "cd tools/build-optimizer && npm run optimize",
    "optimize:assets": "cd tools/build-optimizer && npm run optimize:assets",
    "optimize:split": "cd tools/build-optimizer && npm run optimize:split",
    "analyze": "cd tools/build-optimizer && npm run analyze",
    "analyze:bundle": "cd tools/build-optimizer && npm run analyze:bundle",
    "analyze:treeshake": "cd tools/build-optimizer && npm run analyze:treeshake",
    "analyze:compress": "cd tools/build-optimizer && npm run analyze:compress",
    "budget": "cd tools/build-optimizer && npm run budget",
    "budget:check": "cd tools/build-optimizer && npm run budget:check",
    "budget:batchers": "cd tools/build-optimizer && npm run budget:batchers",
    "build": "npm run build:wasm && npm run build:emcc && vite build",
    "build:optimized": "npm run build:wasm && npm run build:emcc && npm run optimize && vite build",
    "test": "node --experimental-detect-module tests/smoke-runner.mjs",
    "test:wasm": "node tests/wasm.mjs",
    "test:spawn-tracker": "node tests/spawn-tracker.test.mjs",
    "test:world-health": "node tests/world-health.test.mjs",
    "test:wasm-loader": "node tests/wasm-loader-reliability.mjs",
    "test:startup": "node tests/startup-bootstrap.mjs",
    "test:progressive-boot": "node tests/progressive-boot.test.mjs",
    "test:integration": "npm run build:wasm && npm run test:wasm && npm run test:spawn-tracker && npm run test:world-health && npm run test",
    "test:smoke:full": "FULL_BOOT=1 npm run test",
    "test:smoke:fast": "FULL_BOOT=fast npm run test",
    "verify:emcc": "node verification/verify_emcc_exports.js",
    "generate:map": "tsx tools/map-generator/cli.ts",
    "export:map": "tsx tools/map-generator/export-current-world.ts",
    "release:tag": "node scripts/make-release.mjs",
    "release": "npm run build && node scripts/make-release.mjs"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "three": "^0.171.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/three": "^0.171.0",
    "assemblyscript": "^0.27.37",
    "playwright": "^1.59.1",
    "tsx": "^4.7.0",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.5.0"
  }
}
